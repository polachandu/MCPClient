        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "springai-mcp": {
      "command": "/usr/bin/java",
      "args": [
        "-jar",
        "/Users/chandu/Desktop/SpringAI/mcpserverstdio/target/mcpserverstdio-0.0.1-SNAPSHOT.jar"
      ]
    }
  }
}